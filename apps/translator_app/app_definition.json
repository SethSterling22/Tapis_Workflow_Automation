{
    "id": "scientific-nlp-dummy",
    "version": "0.1.1", 
    "description": "Dummy Hello World app for Tapis workflow testing",
    "containerImage": "docker://ghcr.io/sethsterling22/tapis-workflow-automation/tapis-dummy-app:latest",
    "jobType": "FORK",
    "runtime": "SINGULARITY", 
    "executionSystemId": "tacc.ls6.seth.v4",
    "archiveOnAppError": true,
    "jobAttributes": {
        "description": "Initial test for the NL to SL pipeline",
        "parameterSet": {
            "appArgs": [
                {
                    "arg": "test_input.txt",
                    "name": "Dummy Input",
                    "description": "Input filename for the hello_world script"
                }
            ]
        }
    }
}