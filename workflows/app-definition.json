{
    "id": "scientific-processor-app",
    "version": "1.0.0",
    "description": "App to process NL into scientific commands",
    "containerImage": "docker://your-docker-handle/science-image:latest",
    "jobType": "BATCH",
    "runtime": "DOCKER",
    "executionSystemId": "your-execution-system",
    "jobAttributes": {
        "parameterSet": {
        "appArgs": [
            {
            "arg": "--input-file",
            "name": "Input Data",
            "description": "Path to the data to be processed"
            }
        ]
        }
    }
}